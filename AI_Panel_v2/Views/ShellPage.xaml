<Page
    x:Class="AI_Panel_v2.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:AI_Panel_v2.Helpers"
    Loaded="OnLoaded">

    <Grid x:Name="RootLayout" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Border x:Name="BackgroundBlurOverlay"
                Canvas.ZIndex="-1"
                Background="Transparent"
                IsHitTestVisible="False"
                Visibility="Collapsed" />
        <Grid x:Name="AppTitleBar"
              Canvas.ZIndex="1"
              Height="32"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              IsHitTestVisible="True"
              VerticalAlignment="Top">
            <Image Source="/Assets/WindowIcon.ico"
                   HorizontalAlignment="Left"
                   Width="16"
                   Height="16" />
            <TextBlock x:Name="AppTitleBarText"
                       VerticalAlignment="Center"
                       TextWrapping="NoWrap"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Margin="28,0,0,0"/>
        </Grid>
        <NavigationView
            x:Name="NavigationViewControl"
            Canvas.ZIndex="0"
            IsBackButtonVisible="Visible"
            IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}"
            IsSettingsVisible="True"
            IsPaneOpen="False"
            PaneDisplayMode="LeftCompact"
            ExpandedModeThresholdWidth="1280"
            ItemInvoked="NavigationViewControl_ItemInvoked"
            PaneOpened="NavigationViewControl_PaneOpened"
            PaneClosed="NavigationViewControl_PaneClosed"
            DisplayModeChanged="NavigationViewControl_DisplayModeChanged">
            <NavigationView.MenuItems>
                <!--
                TODO: Update item titles by updating <x:Uid>.Content entries in Strings/en-us/Resources.resw.
                https://docs.microsoft.com/windows/uwp/app-resources/localize-strings-ui-manifest#refer-to-a-string-resource-identifier-from-xaml
            
                TODO: Update item icons by updating FontIcon.Glyph properties.
                https://docs.microsoft.com/windows/apps/design/style/segoe-fluent-icons-font#icon-list
                -->
                <NavigationViewItem x:Name="AddWebNavItem" Content="New Page">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xe710;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.PaneFooter>
                <Grid Width="{Binding ElementName=NavigationViewControl, Path=CompactPaneLength}" HorizontalAlignment="Left">
                    <StackPanel HorizontalAlignment="Center" Spacing="2">
                        <ToggleButton x:Name="PinToggleButton"
                                      HorizontalAlignment="Center"
                                      Margin="0"
                                      Padding="0"
                                      Width="40"
                                      Height="36"
                                      MinWidth="40"
                                      MinHeight="36"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RenderTransformOrigin="0.5,0.5"
                                      Click="PinToggleButton_Click"
                                      PointerEntered="PinToggleButton_PointerEntered"
                                      PointerExited="PinToggleButton_PointerExited"
                                      ToolTipService.ToolTip="Pin window on top">
                            <ToggleButton.RenderTransform>
                                <ScaleTransform x:Name="PinToggleScaleTransform" ScaleX="1" ScaleY="1" />
                            </ToggleButton.RenderTransform>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE718;" FontSize="16" />
                        </ToggleButton>
                        <Grid x:Name="LowPowerButton"
                              Width="40"
                              Height="36"
                              MinWidth="40"
                              MinHeight="36"
                              Margin="0"
                              Background="Transparent"
                              HorizontalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5"
                              Tapped="LowPowerButton_Tapped"
                              PointerEntered="LowPowerButton_PointerEntered"
                              PointerExited="LowPowerButton_PointerExited"
                              ToolTipService.ToolTip="Hide to tray and enter low power mode">
                            <Grid.RenderTransform>
                                <CompositeTransform x:Name="LowPowerButtonTransform" ScaleX="1" ScaleY="1" Rotation="0" />
                            </Grid.RenderTransform>
                            <Image x:Name="LowPowerIconImage" Width="29" Height="29" Stretch="Uniform" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </NavigationView.PaneFooter>
            <Grid>
                <Frame x:Name="NavigationFrame" />
            </Grid>
        </NavigationView>
    </Grid>
</Page>
