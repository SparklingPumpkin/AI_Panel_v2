<Page
    x:Class="AI_Panel_v2.Views.WebViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:AI_Panel_v2.Behaviors"
    behaviors:NavigationViewHeaderBehavior.HeaderMode="Never"
    mc:Ignorable="d">

    <Grid x:Name="ContentArea">
        <WebView2 x:Name="WebView" />

        <Border
            x:Name="ExtensionsBarHost"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="8"
            Padding="8,4"
            CornerRadius="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            PointerEntered="ExtensionsBarHost_PointerEntered"
            PointerExited="ExtensionsBarHost_PointerExited">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    VerticalAlignment="Center"
                    Margin="4,0"
                    Text="Extensions" />
                <StackPanel
                    x:Name="ExtensionsButtonsPanel"
                    Orientation="Horizontal"
                    Spacing="6"
                    Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.HasFailures, Mode=OneWay}">
            <TextBlock x:Uid="WebView_FailedMessage" HorizontalAlignment="Center" TextWrapping="WrapWholeWords" />
            <HyperlinkButton x:Uid="WebView_Reload" Command="{x:Bind ViewModel.ReloadCommand}" HorizontalAlignment="Center" />
        </StackPanel>

    </Grid>
</Page>
