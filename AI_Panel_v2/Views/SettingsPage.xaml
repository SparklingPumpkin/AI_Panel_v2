<Page
    x:Class="AI_Panel_v2.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:helpers="using:AI_Panel_v2.Helpers"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    mc:Ignorable="d"
    KeyDown="Page_KeyDown">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <x:Double x:Key="Level1TitleFontSize">20</x:Double>
        <x:Double x:Key="Level2TitleFontSize">15</x:Double>
        <x:Double x:Key="ThemeModeOptionFontSize">15</x:Double>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        </Style>
        <Style x:Key="SecondarySectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="Level1TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{ThemeResource Level1TitleFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="Level2TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{ThemeResource Level2TitleFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Page.Resources>
    <ScrollViewer
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollMode="Enabled"
        VerticalScrollMode="Enabled">
        <Grid x:Name="SettingsLayoutRoot"
              Margin="18"
              Background="Transparent"
              RightTapped="SettingsLayoutRoot_RightTapped">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="ContentArea" Grid.Column="0" Spacing="16" Margin="0,0,10,0">
                <Border x:Name="PersonalizationCard"
                        Style="{StaticResource SectionCardStyle}"
                        PointerPressed="DraggableCard_PointerPressed"
                        PointerMoved="DraggableCard_PointerMoved"
                        PointerReleased="DraggableCard_PointerReleased"
                        PointerCanceled="DraggableCard_PointerReleased">
                    <Border.RenderTransform>
                        <TranslateTransform />
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Personalization" Style="{StaticResource Level1TitleStyle}" x:Name="PersonalizationTitleTextBlock" />
                        <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                            <TextBlock Text="Theme" Style="{StaticResource Level2TitleStyle}" x:Name="ThemeTitleTextBlock" />

                            <Border Margin="{StaticResource XSmallTopMargin}" Style="{StaticResource SecondarySectionCardStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <RadioButton
                                        x:Name="ThemeLightRadioButton"
                                        x:Uid="Settings_Theme_Light"
                                        FontSize="{ThemeResource ThemeModeOptionFontSize}"
                                        Checked="ThemeRadioButton_Checked"
                                        GroupName="AppTheme" />
                                    <RadioButton
                                        x:Name="ThemeDarkRadioButton"
                                        x:Uid="Settings_Theme_Dark"
                                        FontSize="{ThemeResource ThemeModeOptionFontSize}"
                                        Checked="ThemeRadioButton_Checked"
                                        GroupName="AppTheme" />
                                    <RadioButton
                                        x:Name="ThemeDefaultRadioButton"
                                        x:Uid="Settings_Theme_Default"
                                        FontSize="{ThemeResource ThemeModeOptionFontSize}"
                                        Checked="ThemeRadioButton_Checked"
                                        GroupName="AppTheme" />
                                    <RadioButton
                                        x:Name="ThemeCustomRadioButton"
                                        Content="Custom"
                                        FontSize="{ThemeResource ThemeModeOptionFontSize}"
                                        Checked="ThemeRadioButton_Checked"
                                        GroupName="AppTheme" />
                                </StackPanel>
                            </Border>

                            <StackPanel Margin="0,14,0,0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Theme Color (Applied to Theme)" VerticalAlignment="Center" />
                                <Button
                                    x:Name="ThemeColorExpandButton"
                                    Width="30"
                                    Height="30"
                                    Padding="0"
                                    Click="ThemeColorExpandButton_Click"
                                    ToolTipService.ToolTip="Expand/Collapse Theme Color Panel">
                                    <FontIcon x:Name="ThemeColorExpandIcon" FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE70D;" />
                                </Button>
                            </StackPanel>
                            <StackPanel x:Name="ThemeColorPanel"
                                        Margin="{StaticResource XSmallTopMargin}"
                                        Spacing="8"
                                        Visibility="Collapsed">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>
                                    <toolkit:ColorPicker
                                        x:Name="AccentColorPicker"
                                        Grid.Column="0"
                                        Color="LightBlue"
                                        ColorChanged="AccentColorPicker_ColorChanged"
                                        IsAlphaEnabled="True"
                                        IsAlphaSliderVisible="True"
                                        IsColorPaletteVisible="True"
                                        IsColorChannelTextInputVisible="True"
                                        IsColorSliderVisible="True"
                                        IsColorSpectrumVisible="True"
                                        ShowAccentColors="True"
                                        ColorSpectrumShape="Box" />
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <Border Style="{StaticResource SecondarySectionCardStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Opacity" FontWeight="SemiBold" />
                                                <TextBlock Text="IsAlphaEnabled" />
                                                <ToggleSwitch x:Name="AlphaEnabledSwitch" IsOn="True" Toggled="AlphaEnabledSwitch_Toggled" />
                                                <TextBlock Text="IsAlphaSliderVisible" />
                                                <ToggleSwitch x:Name="AlphaSliderSwitch" IsOn="True" Toggled="AlphaSliderSwitch_Toggled" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource SecondarySectionCardStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Input / Slider" FontWeight="SemiBold" />
                                                <TextBlock Text="IsColorSliderVisible" />
                                                <ToggleSwitch x:Name="ColorSliderSwitch" IsOn="True" Toggled="ColorSliderSwitch_Toggled" />
                                                <TextBlock Text="IsColorChannelTextInputVisible" />
                                                <ToggleSwitch x:Name="ColorChannelSwitch" IsOn="True" Toggled="ColorChannelSwitch_Toggled" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource SecondarySectionCardStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Spectrum / Palette" FontWeight="SemiBold" />
                                                <TextBlock Text="IsColorSpectrumVisible" />
                                                <ToggleSwitch x:Name="SpectrumVisibleSwitch" IsOn="True" Toggled="SpectrumVisibleSwitch_Toggled" />
                                                <TextBlock Text="IsColorPaletteVisible" />
                                                <ToggleSwitch x:Name="ColorPaletteSwitch" IsOn="True" Toggled="ColorPaletteSwitch_Toggled" />
                                                <TextBlock Text="ShowAccentColors" />
                                                <ToggleSwitch x:Name="AccentColorsSwitch" IsOn="True" Toggled="AccentColorsSwitch_Toggled" />
                                                <TextBlock Text="ColorSpectrumShape" />
                                                <ComboBox x:Name="SpectrumShapeComboBox" SelectionChanged="SpectrumShapeComboBox_SelectionChanged">
                                                    <x:String>Box</x:String>
                                                    <x:String>Ring</x:String>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="AccentPaletteStatusTextBlock" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Program Font" Style="{StaticResource Level2TitleStyle}" VerticalAlignment="Center" x:Name="ProgramFontTitleTextBlock" />
                            </StackPanel>
                            <StackPanel x:Name="ProgramFontPanel"
                                        Margin="{StaticResource XSmallTopMargin}"
                                        Spacing="8">
                                <TextBlock x:Name="ProgramFontStatusTextBlock" />
                                <Border Style="{StaticResource SecondarySectionCardStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Font Style" FontWeight="SemiBold" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <TextBlock Text="Font Size" />
                                                <Slider x:Name="ProgramFontSizeSlider"
                                                        Minimum="10"
                                                        Maximum="28"
                                                        StepFrequency="1"
                                                        ValueChanged="ProgramFontSizeSlider_ValueChanged" />
                                            </StackPanel>
                                            <ToggleSwitch x:Name="ProgramFontBoldSwitch"
                                                          Grid.Column="1"
                                                          Header="Bold"
                                                          Toggled="ProgramFontBoldSwitch_Toggled" />
                                            <ToggleSwitch x:Name="ProgramFontItalicSwitch"
                                                          Grid.Column="2"
                                                          Header="Italic"
                                                          Toggled="ProgramFontItalicSwitch_Toggled" />
                                            <Button Grid.Column="3"
                                                    Content="Restore Default"
                                                    VerticalAlignment="Bottom"
                                                    Click="RestoreProgramFontButton_Click" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SecondarySectionCardStyle}">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="Font List" FontWeight="SemiBold" />
                                            <Button
                                                x:Name="ProgramFontsListExpandButton"
                                                Width="30"
                                                Height="30"
                                                Padding="0"
                                                Click="ProgramFontsListExpandButton_Click"
                                                ToolTipService.ToolTip="Expand/Collapse Font List">
                                                <FontIcon x:Name="ProgramFontsListExpandIcon" FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE70D;" />
                                            </Button>
                                        </StackPanel>
                                        <StackPanel x:Name="ProgramFontsListPanel" Visibility="Collapsed">
                                            <GridView x:Name="ProgramFontsGridView"
                                                      SelectionMode="Single"
                                                      IsItemClickEnabled="False"
                                                      SelectionChanged="ProgramFontsGridView_SelectionChanged"
                                                      MinHeight="160"
                                                      MaxHeight="280">
                                                <GridView.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                                                    </ItemsPanelTemplate>
                                                </GridView.ItemsPanel>
                                                <GridView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border MinWidth="170" Margin="4" Padding="8" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                                            <StackPanel Spacing="3">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontFamily="{Binding DisplayFontFamily}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </GridView.ItemTemplate>
                                            </GridView>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <TextBlock Margin="0,14,0,0" Text="Background Image" Style="{StaticResource Level2TitleStyle}" x:Name="BackgroundImageTitleTextBlock" />
                            <StackPanel Margin="{StaticResource XSmallTopMargin}" Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="BackgroundImagePathTextBox" Width="360" IsReadOnly="True" PlaceholderText="Select a local image for app background" />
                                <Button Content="Choose Image" Click="ChooseBackgroundImageButton_Click" />
                                <Button Content="Clear" Click="ClearBackgroundImageButton_Click" />
                                <TextBlock x:Name="BackgroundImageStatusTextBlock" VerticalAlignment="Center" />
                            </StackPanel>

                            <Border Margin="0,14,0,0" Style="{StaticResource SecondarySectionCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Opacity Controls" FontWeight="SemiBold" />
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="Background Image Opacity" />
                                            <Slider
                                                x:Name="BackgroundImageOpacitySlider"
                                                Minimum="0"
                                                Maximum="1"
                                                StepFrequency="0.01"
                                                ValueChanged="BackgroundImageOpacitySlider_ValueChanged" />
                                            <TextBlock Text="Background Image Blur" />
                                            <Slider
                                                x:Name="BackgroundImageBlurSlider"
                                                Minimum="0"
                                                Maximum="30"
                                                StepFrequency="1"
                                                ValueChanged="BackgroundImageBlurSlider_ValueChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="Theme Color Opacity" />
                                            <Slider
                                                x:Name="ThemeOpacitySlider"
                                                Minimum="0"
                                                Maximum="1"
                                                StepFrequency="0.01"
                                                ValueChanged="ThemeOpacitySlider_ValueChanged" />
                                            <TextBlock Text="Theme Color Blur" />
                                            <Slider
                                                x:Name="ThemeBlurSlider"
                                                Minimum="0"
                                                Maximum="30"
                                                StepFrequency="1"
                                                ValueChanged="ThemeBlurSlider_ValueChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="Settings Card Opacity" />
                                            <Slider
                                                x:Name="CardOpacitySlider"
                                                Minimum="0"
                                                Maximum="255"
                                                StepFrequency="1"
                                                ValueChanged="CardOpacitySlider_ValueChanged" />
                                            <TextBlock Text="Settings Card Blur" />
                                            <Slider
                                                x:Name="CardBlurSlider"
                                                Minimum="0"
                                                Maximum="30"
                                                StepFrequency="1"
                                                ValueChanged="CardBlurSlider_ValueChanged" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,14,0,0" Style="{StaticResource SecondarySectionCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Settings Card Color" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <toolkit:ColorPickerButton
                                            x:Name="CardColorPickerButton"
                                            SelectedColor="LightBlue" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="GlobalSettingsCard"
                        Style="{StaticResource SectionCardStyle}"
                        PointerPressed="DraggableCard_PointerPressed"
                        PointerMoved="DraggableCard_PointerMoved"
                        PointerReleased="DraggableCard_PointerReleased"
                        PointerCanceled="DraggableCard_PointerReleased">
                    <Border.RenderTransform>
                        <TranslateTransform />
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Global Settings" Style="{StaticResource Level1TitleStyle}" x:Name="GlobalSettingsTitleTextBlock" />

                        <TextBlock Margin="0,8,0,0" Text="Global Hotkey" Style="{StaticResource Level2TitleStyle}" x:Name="GlobalHotkeyTitleTextBlock" />
                        <TextBlock x:Name="HotKeyTextBlock" />
                        <StackPanel Margin="{StaticResource XSmallTopMargin}" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RecordHotKeyButton" Content="Record Hotkey" Click="RecordHotKeyButton_Click" />
                            <Button Content="Save Hotkey" Click="SaveHotKeyButton_Click" />
                            <TextBlock x:Name="HotKeyStatusTextBlock" VerticalAlignment="Center" />
                        </StackPanel>

                        <Border Margin="0,14,0,0" Style="{StaticResource SecondarySectionCardStyle}">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Page Items" Style="{StaticResource Level2TitleStyle}" VerticalAlignment="Center" x:Name="PageItemsTitleTextBlock" />
                                    <Button
                                        x:Name="PageItemsExpandButton"
                                        Width="30"
                                        Height="30"
                                        Padding="0"
                                        Click="PageItemsExpandButton_Click"
                                        ToolTipService.ToolTip="Expand/Collapse Page Items">
                                        <FontIcon x:Name="PageItemsExpandIcon" FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE70D;" />
                                    </Button>
                                </StackPanel>
                                <StackPanel x:Name="PageItemsPanel" Spacing="3" Visibility="Collapsed">
                                    <StackPanel x:Name="WebItemsEditorPanel" Spacing="0" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Add Page Item" Click="AddWebItemButton_Click" />
                                        <Button Content="Save Page Items" Click="SaveWebItemsButton_Click" />
                                        <TextBlock x:Name="WebItemsStatusTextBlock" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,14,0,0" Text="Download Path" Style="{StaticResource Level2TitleStyle}" x:Name="DownloadPathTitleTextBlock" />
                        <StackPanel Margin="{StaticResource XSmallTopMargin}" Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="DownloadPathTextBox" Width="360" PlaceholderText="D:\" />
                            <Button Content="Save Download Path" Click="SaveDownloadPathButton_Click" />
                            <TextBlock x:Name="DownloadPathStatusTextBlock" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="RightColumnStack" Grid.Column="1" Spacing="16" Margin="10,0,0,0">
                <Border x:Name="AboutCard"
                        Style="{StaticResource SectionCardStyle}"
                        PointerPressed="DraggableCard_PointerPressed"
                        PointerMoved="DraggableCard_PointerMoved"
                        PointerReleased="DraggableCard_PointerReleased"
                        PointerCanceled="DraggableCard_PointerReleased">
                    <Border.RenderTransform>
                        <TranslateTransform />
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="About" Style="{StaticResource Level1TitleStyle}" x:Name="AboutTitleTextBlock" />
                        <StackPanel Margin="{StaticResource XSmallTopMargin}">
                            <TextBlock Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" />

                            <TextBlock
                                x:Uid="Settings_AboutDescription"
                                Margin="{StaticResource XSmallTopMargin}"
                                Style="{ThemeResource BodyTextBlockStyle}" />
                            <HyperlinkButton x:Uid="SettingsPage_PrivacyTermsLink" Margin="{StaticResource SettingsPageHyperlinkButtonMargin}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="WebSettingsCard"
                        Style="{StaticResource SectionCardStyle}"
                        PointerPressed="DraggableCard_PointerPressed"
                        PointerMoved="DraggableCard_PointerMoved"
                        PointerReleased="DraggableCard_PointerReleased"
                        PointerCanceled="DraggableCard_PointerReleased">
                    <Border.RenderTransform>
                        <TranslateTransform />
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="Web Settings" Style="{StaticResource Level1TitleStyle}" x:Name="WebSettingsTitleTextBlock" />

                        <Border Margin="0,14,0,0" Style="{StaticResource SecondarySectionCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Web Opacity" Style="{StaticResource Level2TitleStyle}" x:Name="WebOpacityTitleTextBlock" />
                                <TextBlock Text="Control page layer transparency to keep web content readable over injected background image." TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Web Page Layer Opacity" />
                                        <Slider
                                            x:Name="WebLayerOpacitySlider"
                                            Minimum="0"
                                            Maximum="1"
                                            StepFrequency="0.01"
                                            ValueChanged="WebLayerOpacitySlider_ValueChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Web Page Layer Blur" />
                                        <Slider
                                            x:Name="WebLayerBlurSlider"
                                            Minimum="0"
                                            Maximum="30"
                                            StepFrequency="1"
                                            ValueChanged="WebLayerBlurSlider_ValueChanged" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,14,0,0" Text="Targeted Web Beautify" Style="{StaticResource Level2TitleStyle}" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="WrapWholeWords" Text="Configure CSS/JS/HTML files and apply them to specific websites." />
                        <StackPanel Margin="{StaticResource XSmallTopMargin}" Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="WebBeautifyRootPathTextBox" Width="260" PlaceholderText="Beautify files root path" />
                            <Button Content="Save Root Path" Click="SaveWebBeautifyRootPathButton_Click" />
                            <TextBlock x:Name="WebBeautifyRootPathStatusTextBlock" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Margin="{StaticResource XSmallTopMargin}" Style="{StaticResource SecondarySectionCardStyle}">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Rules (URL - file path - enable/disable - delete)" FontWeight="SemiBold" />
                                    <Button Content="Add Rule" Click="AddWebBeautifyRuleButton_Click" />
                                    <Button Content="Save Rules" Click="SaveWebBeautifyRulesButton_Click" />
                                </StackPanel>
                                <StackPanel x:Name="WebBeautifyRulesPanel" Spacing="6" />
                                <TextBlock x:Name="WebBeautifyRulesStatusTextBlock" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,14,0,0" Text="Browser Extensions (WebView2)" Style="{StaticResource Level2TitleStyle}" x:Name="ExtensionsTitleTextBlock" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="WrapWholeWords" Text="Edge Add-ons can be browsed from the link below. Due WebView2 restrictions, install is from unpacked extension folder." />
                        <StackPanel Margin="{StaticResource XSmallTopMargin}" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Install Extension" VerticalAlignment="Center" />
                            <Button
                                x:Name="InstallExtensionExpandButton"
                                Width="30"
                                Height="30"
                                Padding="0"
                                Click="InstallExtensionExpandButton_Click"
                                ToolTipService.ToolTip="Expand/Collapse Extension Details">
                                <FontIcon x:Name="InstallExtensionExpandIcon" FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE70D;" />
                            </Button>
                        </StackPanel>
                        <StackPanel x:Name="InstallExtensionPanel"
                                    Margin="{StaticResource XSmallTopMargin}"
                                    Spacing="8"
                                    Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Open Edge Add-ons" Click="OpenEdgeAddonsButton_Click" />
                                <Button Content="Open App Profile Dev Settings" Click="OpenExtensionDevModeButton_Click" />
                                <Button Content="Refresh Extensions" Click="RefreshExtensionsButton_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="ExtensionFolderPathTextBox" Width="260" PlaceholderText="Unpacked extension folder path" />
                                <Button Content="Install Extension" Click="InstallExtensionButton_Click" />
                                <TextBlock x:Name="ExtensionStatusTextBlock" VerticalAlignment="Center" />
                            </StackPanel>
                            <Border Style="{StaticResource SecondarySectionCardStyle}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Installed Extensions" FontWeight="SemiBold" />
                                    <StackPanel x:Name="ExtensionsRowsPanel" Spacing="6" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
